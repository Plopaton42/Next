{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "isolatedModules": true,
    "useDefineForClassFields": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@components/*": ["components/*"],
      "@tokens/*": ["tokens/build/*"],
      "@composables/*": ["composables/*"]
    }
  },
  "include": ["src", "mcp", "components", "composables", "*.ts", "*.config.ts"],
  "exclude": ["node_modules", "dist", "tokens/build", "vite.config.ts", "vite.lib.config.ts", "vite.css.config.ts"]
}
